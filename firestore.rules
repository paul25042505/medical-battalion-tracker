rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function myUserDoc() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    // 舊資料相容：早期版本把連級主官管存成 "company_commander"。
    function myRole() {
      let r = myUserDoc().role;
      return r == 'company_commander' ? 'commander' : r;
    }
    function myUnit() { return myUserDoc().unit; }
    function isAdmin() { return isSignedIn() && myRole() == 'admin'; }
    function isDutyOfficer() { return isSignedIn() && myRole() == 'duty_officer'; }
    function isStaff() { return isAdmin() || isDutyOfficer(); } // 可查看/管理所有單位
    function isCommander() { return isSignedIn() && myRole() == 'commander'; }
    function isActive() { return isSignedIn() && myRole() != 'pending' && myRole() != 'disabled'; }
    function sameUnit(unit) { return isSignedIn() && myUnit() == unit; }
    // 車長／駕駛／洽公人員都是直接記錄「姓名」字串，跟登入者個人資料的
    // displayName 同步而來（見 personnel 名冊自動同步），比對 displayName
    // 就能知道目前登入者是不是這筆勤務指定的人員——回報（events/vitals）
    // 只開放給這筆勤務本人，不能由同單位其他成員代填。額外放行建立者
    // （createdBy）：建立勤務當下會自動補一筆出勤事件，建立者不一定就是
    // 車長/駕駛本人（可能是幫忙代建立），這筆系統自動寫入不能被擋下來。
    function isAssignedToTaskData(taskData) {
      return request.auth.uid == taskData.createdBy || (
        taskData.type == 'liaison'
          ? (myUserDoc().displayName in taskData.personnel)
          : (myUserDoc().displayName == taskData.crewLeader || myUserDoc().displayName == taskData.driver)
      );
    }

    match /users/{uid} {
      allow get: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == uid
                    && request.resource.data.role == 'pending';
      // 使用者可編輯自己的姓名/階級等資料，但不能自己改 role；已核准後也不能
      // 自己改 unit（只能由管理員 isAdmin 異動）。帳號還在待審核（pending）
      // 階段例外：可以自己選/改單位，方便註冊時先選好單位給管理員審核，
      // 反正待審核狀態本來就沒有任何實際資料存取權限，不构成安全疑慮。
      allow update: if isAdmin()
                    || (isSignedIn() && request.auth.uid == uid
                        && request.resource.data.role == resource.data.role
                        && request.resource.data.unit == resource.data.unit)
                    || (isSignedIn() && request.auth.uid == uid
                        && resource.data.role == 'pending' && request.resource.data.role == 'pending');
      allow delete: if false;
    }

    // 單位編制固定（營部／第一連／第二連），僅供其他集合建立關聯，不提供編輯 UI。
    match /units/{unitId} {
      allow read: if isActive();
      allow write: if isAdmin();
    }

    // 基礎資料：人員／車輛／行車紀錄器，依單位分類。
    // Admin、高勤官可管理所有單位；主官管僅能管理自己單位的資料；
    // 一般成員與主官管都只能讀取自己單位的資料（供建立勤務下拉選單使用）。
    // 帳號綁定單位後，個人資料（姓名/階級/電話）會自動鏡射進同一份人員名冊
    // （文件 id = 使用者 uid），所以自己也需要能更新這份對應到自己的資料；
    // 但跟 users 集合一樣不能自己改 unit，避免藉此跨單位。
    match /personnel/{id} {
      allow read: if isStaff() || sameUnit(resource.data.unit);
      allow create: if isStaff() || (isCommander() && sameUnit(request.resource.data.unit));
      allow update: if isStaff()
                    || (isCommander() && sameUnit(resource.data.unit) && sameUnit(request.resource.data.unit))
                    || (isSignedIn() && request.auth.uid == id && request.resource.data.unit == resource.data.unit);
      allow delete: if isStaff() || (isCommander() && sameUnit(resource.data.unit));
    }
    match /vehicles/{id} {
      allow read: if isStaff() || sameUnit(resource.data.unit);
      allow create: if isStaff() || (isCommander() && sameUnit(request.resource.data.unit));
      allow update, delete: if isStaff() || (isCommander() && sameUnit(resource.data.unit) && sameUnit(request.resource.data.unit));
    }
    match /recorders/{id} {
      allow read: if isStaff() || sameUnit(resource.data.unit);
      allow create: if isStaff() || (isCommander() && sameUnit(request.resource.data.unit));
      allow update, delete: if isStaff() || (isCommander() && sameUnit(resource.data.unit) && sameUnit(request.resource.data.unit));
    }

    match /tasks/{taskId} {
      allow read: if isStaff() || sameUnit(resource.data.unit);
      // 建立勤務限一般成員（限自己單位）與管理員；高勤官、主官管維持督導/查看角色，不再能自己建立。
      allow create: if isAdmin() || (isSignedIn() && myRole() == 'member' && sameUnit(request.resource.data.unit));
      // 高勤官、主官管對勤務只有查看權限：不可編輯、不可刪除（含強制結束），僅 admin 可操作。
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /events/{eventId} {
      // events 皆綁定 taskId 對應的勤務單位；讀取時比對該勤務的 unit，確保伺服器端也真正
      // 限制資料存取範圍，不只是前端隱藏按鈕。
      // 回報（建立 event）僅開放給這筆勤務指定的車長/駕駛/洽公人員本人與 admin
      // （後台支援／強制結束用）；同單位其他成員不能代填沒有被指派到的勤務；
      // 高勤官、主官管屬於督導/查看角色，不進行第一線回報操作。
      allow read: if isStaff() || sameUnit(get(/databases/$(database)/documents/tasks/$(resource.data.taskId)).data.unit);
      allow create: if isAdmin() ||
                    (isSignedIn() && myRole() == 'member'
                     && isAssignedToTaskData(get(/databases/$(database)/documents/tasks/$(request.resource.data.taskId)).data));
      // 時間、里程有時候會回報錯誤，需要能修正；開放對象跟 create 一致
      // （admin 或該筆勤務指定的本人），維持「誰能回報、誰就能修正自己回報的內容」。
      allow update: if isAdmin() ||
                    (isSignedIn() && myRole() == 'member'
                     && isAssignedToTaskData(get(/databases/$(database)/documents/tasks/$(resource.data.taskId)).data));
      // 誤按到不該回報的步驟時要能整筆撤銷；開放對象跟 update 一致。rules 語言
      // 無法查詢「這是不是這筆勤務時間軸上最後一筆事件」（沒有跨文件比較機制），
      // 所以「只能刪最後一筆」這條限制是在前端（見 index.html 的 eventEditModal，
      // 只有時間軸最後一筆才會顯示刪除鈕）執行，rules 這層仍然只把關「誰」能刪
      // （限定該筆勤務指定的本人或 admin），不是把關「刪哪一筆」。
      allow delete: if isAdmin() ||
                    (isSignedIn() && myRole() == 'member'
                     && isAssignedToTaskData(get(/databases/$(database)/documents/tasks/$(resource.data.taskId)).data));
    }

    match /vitals/{id} {
      // 患者生命徵象/主訴紀錄，權限比照 events：誰能回報這筆勤務（admin、
      // 該勤務指定的車長/駕駛/洽公人員本人）就能修正自己填錯的內容；不開放
      // 刪除，避免病歷紀錄憑空消失。
      allow read: if isStaff() || sameUnit(get(/databases/$(database)/documents/tasks/$(resource.data.taskId)).data.unit);
      allow create: if isAdmin() ||
                    (isSignedIn() && myRole() == 'member'
                     && isAssignedToTaskData(get(/databases/$(database)/documents/tasks/$(request.resource.data.taskId)).data));
      allow update: if isAdmin() ||
                    (isSignedIn() && myRole() == 'member'
                     && isAssignedToTaskData(get(/databases/$(database)/documents/tasks/$(resource.data.taskId)).data));
      allow delete: if false;
    }

    // 醫院資訊（急救責任等級/電話）是全營共用的參考資料，不綁定特定單位；
    // 任何在職帳號都能查詢，維護權限比照基礎資料管理（admin、高勤官、主官管）。
    match /hospitals/{id} {
      allow read: if isActive();
      allow create, update, delete: if isStaff() || isCommander();
    }

    // 醫官名冊（姓名/電話）供建立勤務的「值班醫官」欄位選用，是全營共用的
    // 參考資料，不綁定特定單位；維護權限比照基礎資料管理。
    match /doctors/{id} {
      allow read: if isActive();
      allow create, update, delete: if isStaff() || isCommander();
    }

    // 急診待命：兩個醫務所地點固定，每筆文件只存 currentTaskId 指向目前
    // 綁定的待命勤務（實際車號/車長/駕駛/值班醫官資料都在 tasks 集合裡）。
    // 這個指標是建立待命勤務當下由建立者自動寫入，寫入權限比照建立勤務
    // （admin、一般成員）；任何在職帳號都能查看。
    match /erStandby/{id} {
      allow read: if isActive();
      allow create, update: if isAdmin() || (isSignedIn() && myRole() == 'member');
      allow delete: if false;
    }

    // 問題回報／功能建議：任何在職帳號都能送出，只有 admin 能檢視（管理後台
    // 「意見回饋」頁籤），送出後不開放使用者自己修改或刪除，避免爭議。
    match /feedback/{id} {
      allow read: if isAdmin();
      allow create: if isActive() && request.auth.uid == request.resource.data.userId;
      allow update, delete: if false;
    }
  }
}
