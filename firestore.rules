rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function myUserDoc() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    // 舊資料相容：早期版本把連級主官管存成 "company_commander"。
    function myRole() {
      let r = myUserDoc().role;
      return r == 'company_commander' ? 'commander' : r;
    }
    function myUnit() { return myUserDoc().unit; }
    function isAdmin() { return isSignedIn() && myRole() == 'admin'; }
    function isDutyOfficer() { return isSignedIn() && myRole() == 'duty_officer'; }
    function isStaff() { return isAdmin() || isDutyOfficer(); } // 可查看/管理所有單位
    function isCommander() { return isSignedIn() && myRole() == 'commander'; }
    function isActive() { return isSignedIn() && myRole() != 'pending' && myRole() != 'disabled' && myRole() != 'unclaimed'; }
    function sameUnit(unit) { return isSignedIn() && myUnit() == unit; }
    // 只改了 allowedKeys 涵蓋的欄位（例如姓名/階級/電話這類「名冊類」欄位），
    // 不管改了幾個、改成什麼值，只要沒去動 allowedKeys 以外的欄位（尤其是
    // role/unit/email 這幾個帳號權限欄位）就算通過——update 規則用這個把關
    // 「一般成員/主官管能不能自己把 role 或 unit 偷改掉」。
    function onlyChanged(allowedKeys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowedKeys);
    }
    // 車長／駕駛／洽公人員都是直接記錄「姓名」字串，跟登入者個人資料的
    // displayName 比對——比對 displayName 就能知道目前登入者是不是這筆
    // 勤務指定的人員——回報（events/vitals）只開放給這筆勤務指定的人員
    // 本人，不能由同單位其他成員代填。額外放行建立者（createdBy）：建立
    // 勤務當下會自動補一筆出勤事件，建立者不一定就是車長/駕駛本人（可能
    // 是幫忙代建立），這筆系統自動寫入不能被擋下來。
    function isAssignedToTaskData(taskData) {
      return request.auth.uid == taskData.createdBy || (
        taskData.type == 'liaison'
          ? (myUserDoc().displayName in taskData.personnel)
          : (myUserDoc().displayName == taskData.crewLeader || myUserDoc().displayName == taskData.driver)
      );
    }

    // 帳號與人員名冊合併成同一份集合（原本 users／personnel 兩份分開維護，
    // 一份存帳號權限、一份存花名冊，同一個人要對照兩邊資料容易搞混，也曾經
    // 需要一支背景同步機制讓兩邊不要對不起來）。現在每個人只有一筆文件，
    // role 多一個 'unclaimed' 狀態代表「管理員先預建好資料，這個人還沒
    // 登入過」，登入時用信箱比對、由後端 Cloud Function（onUserCreated）
    // 自動把這筆資料轉成用真實帳號 uid 命名的正式文件（詳見
    // functions/index.js）。
    //
    // 讀取：admin／高勤官不分單位；一般成員/主官管只能看自己單位的（供
    // 建立勤務下拉選單使用）——跟原本 personnel 集合的讀取範圍一致，只是
    // 現在同一份文件裡也看得到 role/email，這是合併資料模型必然的取捨。
    //
    // 寫入分三種身分：
    // 1) admin：什麼欄位都能改（角色/單位指派、花名冊資料都算）。
    // 2) 本人：只能改「名冊類」欄位（displayName/rank/phone/emtLevel）跟
    //    fcmTokens（開關推播通知要用），不能碰 role/unit/email，避免自己
    //    偷改權限或跨單位。
    // 3) 高勤官（不分單位）／主官管（限自己單位、且改前改後單位不變）：
    //    可以改其他人的「名冊類」欄位（例如幫同單位的人補電話），但一樣
    //    不能碰 role/unit/email——這幾個欄位的異動只有 admin 能做。
    match /users/{uid} {
      // 本人一定要能讀到自己的文件，而且這個判斷不能經過 isStaff()／
      // sameUnit()（兩者都會呼叫 myUserDoc() 對自己的 uid 做 get()）：
      // 使用者第一次登入時，自己的 users/{uid} 文件根本還不存在，
      // get() 對不存在的文件求值會噴錯，導致整條 || 判斷式失敗、
      // 回傳 403，新帳號會卡在「登入後初始化失敗」動彈不得。
      // request.auth.uid == uid 純粹比對路徑跟權杖，不會呼叫 get()，
      // 排在最前面才能確保這個 short-circuit 一定先被評估到。
      allow read: if (isSignedIn() && request.auth.uid == uid) || isStaff() || sameUnit(resource.data.unit);
      // 建立分兩種情境：(a) 使用者自己第一次登入，前端自動建立一筆
      // role:'pending'、unit 空白的待審核帳號；(b) 管理員/高勤官/主官管
      // 幫還沒登入過的人預先建立資料，role 一定要是 'unclaimed'，不能藉
      // 這個路徑直接生出一個 admin/其他高權限帳號。
      allow create: if (isSignedIn() && request.auth.uid == uid
                        && request.resource.data.role == 'pending' && request.resource.data.unit == '')
                    || (request.resource.data.role == 'unclaimed'
                        && (isStaff() || (isCommander() && sameUnit(request.resource.data.unit))));
      allow update: if isAdmin()
                    // 待審核（pending）階段專用：這個階段可以自己選/改單位，
                    // 方便管理員審核（見 index.html 的 updatePendingProfile）；
                    // 一旦通過審核就不再適用這條，不能自己再改單位逃去別的單位。
                    || (isSignedIn() && request.auth.uid == uid && resource.data.role == 'pending'
                        && onlyChanged(['unit','displayName','rank','phone','emtLevel','fcmTokens']))
                    || (isSignedIn() && request.auth.uid == uid
                        && onlyChanged(['displayName','rank','phone','emtLevel','fcmTokens']))
                    || ((isDutyOfficer() || (isCommander() && sameUnit(resource.data.unit) && sameUnit(request.resource.data.unit)))
                        && onlyChanged(['displayName','rank','phone','emtLevel']));
      // 只能刪除還沒被登入認領過的預建資料（role 'unclaimed'）；已經是
      // 真實帳號的文件一律不能刪除，跟原本 users 集合的規則一致。
      allow delete: if resource.data.role == 'unclaimed'
                    && (isStaff() || (isCommander() && sameUnit(resource.data.unit)));
    }

    // 單位編制固定（營部／第一連／第二連），僅供其他集合建立關聯，不提供編輯 UI。
    match /units/{unitId} {
      allow read: if isActive();
      allow write: if isAdmin();
    }

    // 基礎資料：車輛／行車紀錄器，依單位分類（人員已併入 users 集合，
    // 見上方 match /users/{uid} 的說明）。
    // Admin、高勤官可管理所有單位；主官管僅能管理自己單位的資料；
    // 一般成員與主官管都只能讀取自己單位的資料（供建立勤務下拉選單使用）。
    match /vehicles/{id} {
      allow read: if isStaff() || sameUnit(resource.data.unit);
      allow create: if isStaff() || (isCommander() && sameUnit(request.resource.data.unit));
      allow update, delete: if isStaff() || (isCommander() && sameUnit(resource.data.unit) && sameUnit(request.resource.data.unit));
    }
    match /recorders/{id} {
      allow read: if isStaff() || sameUnit(resource.data.unit);
      allow create: if isStaff() || (isCommander() && sameUnit(request.resource.data.unit));
      allow update, delete: if isStaff() || (isCommander() && sameUnit(resource.data.unit) && sameUnit(request.resource.data.unit));
    }

    match /tasks/{taskId} {
      allow read: if isStaff() || sameUnit(resource.data.unit);
      // 建立勤務限一般成員（限自己單位）與管理員；高勤官、主官管維持督導/查看角色，不再能自己建立。
      allow create: if isAdmin() || (isSignedIn() && myRole() == 'member' && sameUnit(request.resource.data.unit));
      // 高勤官、主官管對勤務只有查看權限：不可編輯、不可刪除（含強制結束），僅 admin 可操作。
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /events/{eventId} {
      // events 皆綁定 taskId 對應的勤務單位；讀取時比對該勤務的 unit，確保伺服器端也真正
      // 限制資料存取範圍，不只是前端隱藏按鈕。
      // 回報（建立 event）僅開放給這筆勤務指定的車長/駕駛/洽公人員本人與 admin
      // （後台支援／強制結束用）；同單位其他成員不能代填沒有被指派到的勤務；
      // 高勤官、主官管屬於督導/查看角色，不進行第一線回報操作。
      allow read: if isStaff() || sameUnit(get(/databases/$(database)/documents/tasks/$(resource.data.taskId)).data.unit);
      allow create: if isAdmin() ||
                    (isSignedIn() && myRole() == 'member'
                     && isAssignedToTaskData(get(/databases/$(database)/documents/tasks/$(request.resource.data.taskId)).data));
      // 時間、里程有時候會回報錯誤，需要能修正；開放對象跟 create 一致
      // （admin 或該筆勤務指定的本人），維持「誰能回報、誰就能修正自己回報的內容」。
      allow update: if isAdmin() ||
                    (isSignedIn() && myRole() == 'member'
                     && isAssignedToTaskData(get(/databases/$(database)/documents/tasks/$(resource.data.taskId)).data));
      // 誤按到不該回報的步驟時要能整筆撤銷；開放對象跟 update 一致。rules 語言
      // 無法查詢「這是不是這筆勤務時間軸上最後一筆事件」（沒有跨文件比較機制），
      // 所以「只能刪最後一筆」這條限制是在前端（見 index.html 的 eventEditModal，
      // 只有時間軸最後一筆才會顯示刪除鈕）執行，rules 這層仍然只把關「誰」能刪
      // （限定該筆勤務指定的本人或 admin），不是把關「刪哪一筆」。
      allow delete: if isAdmin() ||
                    (isSignedIn() && myRole() == 'member'
                     && isAssignedToTaskData(get(/databases/$(database)/documents/tasks/$(resource.data.taskId)).data));
    }

    match /vitals/{id} {
      // 患者生命徵象/主訴紀錄，權限比照 events：誰能回報這筆勤務（admin、
      // 該勤務指定的車長/駕駛/洽公人員本人）就能修正自己填錯的內容；不開放
      // 刪除，避免病歷紀錄憑空消失。
      allow read: if isStaff() || sameUnit(get(/databases/$(database)/documents/tasks/$(resource.data.taskId)).data.unit);
      allow create: if isAdmin() ||
                    (isSignedIn() && myRole() == 'member'
                     && isAssignedToTaskData(get(/databases/$(database)/documents/tasks/$(request.resource.data.taskId)).data));
      allow update: if isAdmin() ||
                    (isSignedIn() && myRole() == 'member'
                     && isAssignedToTaskData(get(/databases/$(database)/documents/tasks/$(resource.data.taskId)).data));
      allow delete: if false;
    }

    // 醫院資訊（急救責任等級/電話）是全營共用的參考資料，不綁定特定單位；
    // 任何在職帳號都能查詢，維護權限比照基礎資料管理（admin、高勤官、主官管）。
    match /hospitals/{id} {
      allow read: if isActive();
      allow create, update, delete: if isStaff() || isCommander();
    }

    // 醫官名冊（姓名/電話）供建立勤務的「值班醫官」欄位選用，是全營共用的
    // 參考資料，不綁定特定單位；維護權限比照基礎資料管理。
    match /doctors/{id} {
      allow read: if isActive();
      allow create, update, delete: if isStaff() || isCommander();
    }

    // 急診待命：兩個醫務所地點固定，每筆文件只存 currentTaskId 指向目前
    // 綁定的待命勤務（實際車號/車長/駕駛/值班醫官資料都在 tasks 集合裡）。
    // 這個指標是建立待命勤務當下由建立者自動寫入，寫入權限比照建立勤務
    // （admin、一般成員）；任何在職帳號都能查看。
    match /erStandby/{id} {
      allow read: if isActive();
      allow create, update: if isAdmin() || (isSignedIn() && myRole() == 'member');
      allow delete: if false;
    }

    // 問題回報／功能建議：任何在職帳號都能送出，只有 admin 能檢視（管理後台
    // 「意見回饋」頁籤），送出後不開放使用者自己修改或刪除，避免爭議。
    match /feedback/{id} {
      allow read: if isAdmin();
      allow create: if isActive() && request.auth.uid == request.resource.data.userId;
      allow update, delete: if false;
    }

    // 通知中心（收件匣歷史紀錄）／訊息管理（公告）：任何在職帳號都能查看、
    // 標記已讀（isRead 是整份文件共用的欄位，不分帳號各自已讀狀態，一般
    // 帳號只開放改這一個欄位）；公告本身（新增/編輯標題內容/刪除）只有
    // admin 能在「訊息管理」操作。
    match /notifications/{id} {
      allow read: if isActive();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (isActive() && onlyChanged(['isRead']));
    }
  }
}
