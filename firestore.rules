rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function myUserDoc() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    // 舊資料相容：早期版本把連級主官管存成 "company_commander"。
    function myRole() {
      let r = myUserDoc().role;
      return r == 'company_commander' ? 'commander' : r;
    }
    function myUnit() { return myUserDoc().unit; }
    function isAdmin() { return isSignedIn() && myRole() == 'admin'; }
    function isDutyOfficer() { return isSignedIn() && myRole() == 'duty_officer'; }
    function isStaff() { return isAdmin() || isDutyOfficer(); } // 可查看/管理所有單位
    function isCommander() { return isSignedIn() && myRole() == 'commander'; }
    function isActive() { return isSignedIn() && myRole() != 'pending' && myRole() != 'disabled' && myRole() != 'unclaimed'; }
    function sameUnit(unit) { return isSignedIn() && myUnit() == unit; }
    // 只改了 allowedKeys 涵蓋的欄位（例如姓名/階級/電話這類「名冊類」欄位），
    // 不管改了幾個、改成什麼值，只要沒去動 allowedKeys 以外的欄位（尤其是
    // role/unit/email 這幾個帳號權限欄位）就算通過——update 規則用這個把關
    // 「一般成員/主官管能不能自己把 role 或 unit 偷改掉」。
    function onlyChanged(allowedKeys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowedKeys);
    }
    // 車長／駕駛／洽公人員都是直接記錄「姓名」字串，跟登入者個人資料的
    // displayName 比對——比對 displayName 就能知道目前登入者是不是這筆
    // 勤務指定的人員——回報（events/vitals）只開放給這筆勤務指定的人員
    // 本人，不能由同單位其他成員代填。額外放行建立者（createdBy）：建立
    // 勤務當下會自動補一筆出勤事件，建立者不一定就是車長/駕駛本人（可能
    // 是幫忙代建立），這筆系統自動寫入不能被擋下來。
    function isAssignedToTaskData(taskData) {
      return request.auth.uid == taskData.createdBy || (
        taskData.type == 'liaison'
          ? (myUserDoc().displayName in taskData.personnel)
          : (myUserDoc().displayName == taskData.crewLeader || myUserDoc().displayName == taskData.driver)
      );
    }
    // 編輯勤務用的「本人是不是這筆任務的車長/駕駛/洽公人員」判斷，故意不
    // 比照 isAssignedToTaskData() 額外放行 createdBy——編輯權限只給「任務
    // 裡面的人」本人（使用者的原話），代建立任務的人不算，跟事件/生命徵象
    // 回報開放建立者代填是不同的情境，這裡不能沿用同一個函式。
    function isCrewOfTask(taskData) {
      return taskData.type == 'liaison'
        ? (myUserDoc().displayName in taskData.personnel)
        : (myUserDoc().displayName == taskData.crewLeader || myUserDoc().displayName == taskData.driver);
    }
    // 判斷某個時間戳記跟現在是不是台灣在地時區（UTC+8）的同一個日曆日：
    // 兩邊都先加上 8 小時位移量再取「第幾天」比較，才是比較台灣在地的日期，
    // 不是單純比較 UTC 日期（否則台灣已經跨日、UTC 還沒跨日這種邊界會誤判）。
    function isSameLocalDayAsNow(ts) {
      let tzMs = 8 * 60 * 60 * 1000;
      return math.floor((request.time.toMillis() + tzMs) / 86400000) == math.floor((ts.toMillis() + tzMs) / 86400000);
    }

    // 帳號與人員名冊合併成同一份集合（原本 users／personnel 兩份分開維護，
    // 一份存帳號權限、一份存花名冊，同一個人要對照兩邊資料容易搞混，也曾經
    // 需要一支背景同步機制讓兩邊不要對不起來）。現在每個人只有一筆文件，
    // role 多一個 'unclaimed' 狀態代表「管理員先預建好資料，這個人還沒
    // 登入過」，登入時用信箱比對、由後端 Cloud Function（onUserCreated）
    // 自動把這筆資料轉成用真實帳號 uid 命名的正式文件（詳見
    // functions/index.js）。
    //
    // 讀取：admin／高勤官不分單位；一般成員/主官管只能看自己單位的（供
    // 建立勤務下拉選單使用）——跟原本 personnel 集合的讀取範圍一致，只是
    // 現在同一份文件裡也看得到 role/email，這是合併資料模型必然的取捨。
    //
    // 寫入分三種身分：
    // 1) admin：什麼欄位都能改（角色/單位指派、花名冊資料都算）。
    // 2) 本人：只能改「名冊類」欄位（displayName/rank/phone/emtLevel）跟
    //    fcmTokens（開關推播通知要用）、pushPermission/pushDevice/
    //    pushSubscribedAt（推播控制台用，裝置自我回報通知權限狀態／裝置
    //    種類／訂閱時間，只有自己的裝置讀得到這些資訊，不能由他人代填），
    //    不能碰 role/unit/email，避免自己偷改權限或跨單位。
    // 3) 高勤官（不分單位）／主官管（限自己單位、且改前改後單位不變）：
    //    可以改其他人的「名冊類」欄位（例如幫同單位的人補電話），但一樣
    //    不能碰 role/unit/email——這幾個欄位的異動只有 admin 能做。
    match /users/{uid} {
      // 本人一定要能讀到自己的文件，而且這個判斷不能經過 isStaff()／
      // sameUnit()（兩者都會呼叫 myUserDoc() 對自己的 uid 做 get()）：
      // 使用者第一次登入時，自己的 users/{uid} 文件根本還不存在，
      // get() 對不存在的文件求值會噴錯，導致整條 || 判斷式失敗、
      // 回傳 403，新帳號會卡在「登入後初始化失敗」動彈不得。
      // request.auth.uid == uid 純粹比對路徑跟權杖，不會呼叫 get()，
      // 排在最前面才能確保這個 short-circuit 一定先被評估到。
      allow read: if (isSignedIn() && request.auth.uid == uid) || isStaff() || sameUnit(resource.data.unit);
      // 建立分兩種情境：(a) 使用者自己第一次登入，前端自動建立一筆
      // role:'pending'、unit 空白的待審核帳號；(b) 管理員/高勤官/主官管
      // 幫還沒登入過的人預先建立資料，role 一定要是 'unclaimed'，不能藉
      // 這個路徑直接生出一個 admin/其他高權限帳號。
      allow create: if (isSignedIn() && request.auth.uid == uid
                        && request.resource.data.role == 'pending' && request.resource.data.unit == '')
                    || (request.resource.data.role == 'unclaimed'
                        && (isStaff() || (isCommander() && sameUnit(request.resource.data.unit))));
      allow update: if isAdmin()
                    // 待審核（pending）階段專用：這個階段可以自己選/改單位，
                    // 方便管理員審核（見 index.html 的 updatePendingProfile）；
                    // 一旦通過審核就不再適用這條，不能自己再改單位逃去別的單位。
                    || (isSignedIn() && request.auth.uid == uid && resource.data.role == 'pending'
                        && onlyChanged(['unit','displayName','rank','phone','emtLevel','vehicleType','vehicleBrand','vehiclePlate','fcmTokens','pushPermission','pushDevice','pushSubscribedAt']))
                    || (isSignedIn() && request.auth.uid == uid
                        && onlyChanged(['displayName','rank','phone','emtLevel','vehicleType','vehicleBrand','vehiclePlate','fcmTokens','pushPermission','pushDevice','pushSubscribedAt']))
                    || ((isDutyOfficer() || (isCommander() && sameUnit(resource.data.unit) && sameUnit(request.resource.data.unit)))
                        && onlyChanged(['displayName','rank','phone','emtLevel']));
      // 只能刪除還沒被登入認領過的預建資料（role 'unclaimed'）；已經是
      // 真實帳號的文件一律不能刪除，跟原本 users 集合的規則一致。
      allow delete: if resource.data.role == 'unclaimed'
                    && (isStaff() || (isCommander() && sameUnit(resource.data.unit)));
    }

    // 單位編制固定（營部／第一連／第二連），僅供其他集合建立關聯，不提供編輯 UI。
    match /units/{unitId} {
      allow read: if isActive();
      allow write: if isAdmin();
    }

    // 系統層級參數設定（目前只有 settings/testMode：管理員測試模式，見
    // functions/index.js 的 isTestModeActive／index.html 的「系統設定」
    // 頁），只有 admin 能讀寫，不開放給其他角色（含高勤官、主官管）。
    match /settings/{id} {
      allow read, write: if isAdmin();
    }

    // 基礎資料：車輛／行車紀錄器，依單位分類（人員已併入 users 集合，
    // 見上方 match /users/{uid} 的說明）。
    // Admin、高勤官可管理所有單位；主官管僅能管理自己單位的資料；
    // 一般成員與主官管都只能讀取自己單位的資料（供建立勤務下拉選單使用）。
    match /vehicles/{id} {
      allow read: if isStaff() || sameUnit(resource.data.unit);
      allow create: if isStaff() || (isCommander() && sameUnit(request.resource.data.unit));
      allow update, delete: if isStaff() || (isCommander() && sameUnit(resource.data.unit) && sameUnit(request.resource.data.unit));
    }
    match /recorders/{id} {
      allow read: if isStaff() || sameUnit(resource.data.unit);
      allow create: if isStaff() || (isCommander() && sameUnit(request.resource.data.unit));
      allow update, delete: if isStaff() || (isCommander() && sameUnit(resource.data.unit) && sameUnit(request.resource.data.unit));
    }

    match /tasks/{taskId} {
      // 一般勤務維持原本限制（本單位或 staff 才能讀取）。急診待命的醫務所
      // 地點是全營共用資源，例外開放：erStandbyKey 只有透過急診待命頁建立
      // 的勤務才會寫入這個欄位（見 index.html 的 __createTask），一般勤務
      // 沒有這個欄位，不受這條例外影響。開放讀取的別單位待命勤務只是
      // 調度層級的摘要（車號/車長/駕駛/值班醫官），不含患者資料——前端把
      // 「點進去看詳情」這個動作鎖住，不代表其他單位、不給操作（見
      // index.html 的 viewErStandby／canViewTaskDetail）；真正的患者資料
      // （events/vitals）仍然限本單位讀取，就算前端沒鎖住點擊，點進另一個
      // 單位的待命勤務詳情頁也看不到患者資料。
      //
      // 跨單位借用資源（跨單位借車／跨單位選人）時，這筆勤務會多記一個
      // involvedUnits 陣列（借用到的別單位清單，見 index.html 的
      // computeInvolvedUnits／createTask／updateTask）；只開放該單位的
      // 主官管讀取（不含一般成員），且看得到完整內容（不像急診待命只給
      // 摘要）——這是使用者明確選擇的範圍：跨單位可見性只到主官管層級，
      // 不擴及該單位全體成員。
      allow read: if isStaff() || sameUnit(resource.data.unit) || ('erStandbyKey' in resource.data)
                  || (isCommander() && 'involvedUnits' in resource.data && myUnit() in resource.data.involvedUnits);
      // 建立勤務限一般成員（限自己單位）與管理員；高勤官、主官管維持督導/查看角色，不再能自己建立。
      allow create: if isAdmin() || (isSignedIn() && myRole() == 'member' && sameUnit(request.resource.data.unit));
      // 高勤官、主官管對勤務維持只有查看權限：不可編輯。一般成員只能編輯
      // 自己被指派（車長/駕駛/洽公人員本人）的勤務，且只限建立當天——過了
      // 當天 24:00（台灣在地時區）這筆任務就算進了紀錄查詢的歷史資料，
      // 只剩 admin 能再改，避免本人事後任意竄改已經成為歷史紀錄的內容。
      allow update: if isAdmin() ||
                    (isSignedIn() && myRole() == 'member' && isCrewOfTask(resource.data) && isSameLocalDayAsNow(resource.data.createdAt));
      // 刪除（含強制結束）僅 admin 可操作，不開放給一般成員。
      allow delete: if isAdmin();
    }

    match /events/{eventId} {
      // events 皆綁定 taskId 對應的勤務單位；讀取時比對該勤務的 unit，確保伺服器端也真正
      // 限制資料存取範圍，不只是前端隱藏按鈕。
      // 回報（建立 event）僅開放給這筆勤務指定的車長/駕駛/洽公人員本人與 admin
      // （後台支援／強制結束用）；同單位其他成員不能代填沒有被指派到的勤務；
      // 高勤官、主官管屬於督導/查看角色，不進行第一線回報操作。
      //
      // 讀取權限比對這筆 event 自己的 unit 欄位（建立時就從所屬勤務複製過來，
      // 見 index.html 的 addEvent），不是每次都額外 get() 勤務文件查 unit——
      // 這裡曾經用 get() 查勤務單位，但這樣一來，一般成員／主官管的清單查詢
      // 因為 rules 判斷式依賴的是「查詢範圍以外」的另一份文件（tasks），
      // Firestore 沒辦法單靠查詢本身的 where 條件證明每一筆結果都符合權限，
      // 會整批查詢直接被拒絕（跟 pushLog 曾經踩過的坑同一種成因，見
      // fsQueryEquals 的說明）；改成直接比對這筆文件自己的 unit 欄位，前端才
      // 能加上 where unit==自己單位 的查詢條件，讓 Firestore 能夠證明查詢安全。
      //
      // 跨單位借用資源時同樣複製一份 involvedUnits（見 index.html 的
      // addEvent），只開放該單位主官管讀取，理由跟上面 tasks 的說明一致——
      // 使用者選擇讓借用單位的主官管看得到完整患者紀錄內容，不是只有摘要。
      allow read: if isStaff() || sameUnit(resource.data.unit)
                  || (isCommander() && 'involvedUnits' in resource.data && myUnit() in resource.data.involvedUnits);
      allow create: if isAdmin() ||
                    (isSignedIn() && myRole() == 'member'
                     && isAssignedToTaskData(get(/databases/$(database)/documents/tasks/$(request.resource.data.taskId)).data));
      // 時間、里程有時候會回報錯誤，需要能修正；開放對象跟 create 一致
      // （admin 或該筆勤務指定的本人），維持「誰能回報、誰就能修正自己回報的內容」。
      allow update: if isAdmin() ||
                    (isSignedIn() && myRole() == 'member'
                     && isAssignedToTaskData(get(/databases/$(database)/documents/tasks/$(resource.data.taskId)).data));
      // 誤按到不該回報的步驟時要能整筆撤銷；開放對象跟 update 一致。rules 語言
      // 無法查詢「這是不是這筆勤務時間軸上最後一筆事件」（沒有跨文件比較機制），
      // 所以「只能刪最後一筆」這條限制是在前端（見 index.html 的 eventEditModal，
      // 只有時間軸最後一筆才會顯示刪除鈕）執行，rules 這層仍然只把關「誰」能刪
      // （限定該筆勤務指定的本人或 admin），不是把關「刪哪一筆」。
      allow delete: if isAdmin() ||
                    (isSignedIn() && myRole() == 'member'
                     && isAssignedToTaskData(get(/databases/$(database)/documents/tasks/$(resource.data.taskId)).data));
    }

    match /vitals/{id} {
      // 患者生命徵象/主訴紀錄，權限比照 events：誰能回報這筆勤務（admin、
      // 該勤務指定的車長/駕駛/洽公人員本人）就能修正自己填錯的內容；不開放
      // 刪除，避免病歷紀錄憑空消失。
      // 讀取權限比對這筆 vitals 自己的 unit 欄位（建立時就從所屬勤務複製過來，
      // 見 index.html 的 addVitalsEntry），理由跟上面 events 的說明一致。
      // 跨單位借用資源時同樣開放該單位主官管讀取完整內容，理由跟 tasks 一致。
      allow read: if isStaff() || sameUnit(resource.data.unit)
                  || (isCommander() && 'involvedUnits' in resource.data && myUnit() in resource.data.involvedUnits);
      allow create: if isAdmin() ||
                    (isSignedIn() && myRole() == 'member'
                     && isAssignedToTaskData(get(/databases/$(database)/documents/tasks/$(request.resource.data.taskId)).data));
      allow update: if isAdmin() ||
                    (isSignedIn() && myRole() == 'member'
                     && isAssignedToTaskData(get(/databases/$(database)/documents/tasks/$(resource.data.taskId)).data));
      allow delete: if false;
    }

    // 醫院資訊（急救責任等級/電話）是全營共用的參考資料，不綁定特定單位；
    // 任何在職帳號都能查詢。新增一筆會影響所有單位查到的清單，只有 admin
    // 能新增，避免高勤官/主官管誤增到重複或不精確的醫院資料；既有資料的
    // 編輯／刪除維持原本比照基礎資料管理（admin、高勤官、主官管）不變。
    match /hospitals/{id} {
      allow read: if isActive();
      allow create: if isAdmin();
      allow update, delete: if isStaff() || isCommander();
    }

    // 醫官名冊（姓名/電話）供建立勤務的「值班醫官」欄位選用，是全營共用的
    // 參考資料，不綁定特定單位；維護權限比照基礎資料管理。
    match /doctors/{id} {
      allow read: if isActive();
      allow create, update, delete: if isStaff() || isCommander();
    }

    // 建立勤務頁「任務名稱」快速選擇範本，是全營共用的參考資料，不綁定
    // 特定單位；維護權限比照基礎資料管理。
    match /taskTitleTemplates/{id} {
      allow read: if isActive();
      allow create, update, delete: if isStaff() || isCommander();
    }

    // 網網相連：後台管理的常用網址快速切換清單，是全營共用的參考資料，
    // 不綁定特定單位；維護權限比照基礎資料管理。
    match /webLinks/{id} {
      allow read: if isActive();
      allow create, update, delete: if isStaff() || isCommander();
    }

    // 軍品攜帶：後台管理的軍品項目名冊（武器裝備／通信裝備），是全營共用的
    // 參考資料，不綁定特定單位；維護權限比照基礎資料管理。
    match /militaryItems/{id} {
      allow read: if isActive();
      allow create, update, delete: if isStaff() || isCommander();
    }

    // 健保署急診即時資訊快取（見 functions/index.js 的 syncErRealtime，每
    // 15 分鐘排程呼叫一次），只有這支排程函式（Admin SDK，本來就不受安全
    // 規則限制）會寫入，一般使用者/前端一律唯讀，不開放任何人直接寫入。
    match /erRealtime/{id} {
      allow read: if isActive();
      allow write: if false;
    }

    // 急診待命：兩個醫務所地點固定，每筆文件只存 currentTaskId 指向目前
    // 綁定的待命勤務（實際車號/車長/駕駛/值班醫官資料都在 tasks 集合裡）。
    // 這個指標是建立待命勤務當下由建立者自動寫入，寫入權限比照建立勤務
    // （admin、一般成員）；任何在職帳號都能查看。
    match /erStandby/{id} {
      allow read: if isActive();
      allow create, update: if isAdmin() || (isSignedIn() && myRole() == 'member');
      allow delete: if false;
    }

    // 問題回報／功能建議：任何在職帳號都能送出，只有 admin 能檢視（管理後台
    // 「意見回饋」頁籤），送出後不開放使用者自己修改或刪除，避免爭議。
    match /feedback/{id} {
      allow read: if isAdmin();
      allow create: if isActive() && request.auth.uid == request.resource.data.userId;
      allow update, delete: if false;
    }

    // 通知中心（收件匣歷史紀錄）／訊息管理（公告）：任何在職帳號都能查看、
    // 標記已讀（isRead 是整份文件共用的欄位，不分帳號各自已讀狀態，一般
    // 帳號只開放改這一個欄位）；公告本身（新增/編輯標題內容/刪除）只有
    // admin 能在「訊息管理」操作。
    //
    // 主官管、高勤官另外開放「發送推播訊息」（見 index.html 的
    // window.__sendCommanderBroadcast）：主官管只能新增帶自己單位的訊息
    // （不能替其他單位發送）；高勤官不像主官管有固定的單一單位（跟 admin
    // 一樣不分單位），開放帶任一單位、或完全不帶 unit（等同全體公告）。
    // 兩者都不開放編輯／刪除（跟 admin 的全體公告一樣，發出去就發出去了）。
    //
    // read 這裡刻意維持 isActive()（不分單位都能讀），沒有比照 tasks 那樣
    // 加上單位限制：notifications 目前是「全體公告＋單位訊息」混合的單一
    // 集合，client 端固定用不帶 where 條件的整批 list 撈全部（見
    // notificationsPoll／fsListCollection），Firestore 對這種不帶篩選條件
    // 的 list 查詢一樣要求規則必須「整批」都通得過、不能逐筆篩選——如果
    // 規則依賴 resource.data.unit 個別比對，任何一則跟自己單位不同的
    // 單位訊息存在，就會讓整批 list 直接被拒絕，連原本看得到的全體公告
    // 也讀不到。因此這裡的隔離做在前端（見 index.html 的
    // visiblePersonalNotifications，只有 unit 相符或沒有 unit 欄位的
    // 全體公告才會顯示），不是嚴格的伺服器端讀取限制——單位訊息內容本身
    // 定位為一般性的公告/連絡事項（不含患者個資），權衡後接受這個折衷。
    match /notifications/{id} {
      allow read: if isActive();
      allow create: if isAdmin() || isDutyOfficer() || (isCommander() && request.resource.data.unit == myUnit());
      allow delete: if isAdmin();
      allow update: if isAdmin() || (isActive() && onlyChanged(['isRead']));
    }

    // 系統實際推播過的內容，個人化紀錄（見 functions/index.js 的
    // writePushLog）：只有這則通知指定的那個人（uid 等於自己）能讀到、
    // 能標記已讀，跟 notifications（全體共用的公告板）不一樣，不能套用
    // 同一條「isActive() 就能讀」的規則，否則等於誰都能看到別人收到的
    // 任務/生命徵象異常等推播內容。只有後端 Cloud Function（Admin SDK，
    // 不受這份規則限制）會寫入/刪除，前端不開放直接新增或刪除。
    match /pushLog/{id} {
      allow read: if isActive() && request.auth.uid == resource.data.uid;
      allow update: if isActive() && request.auth.uid == resource.data.uid && onlyChanged(['isRead']);
      allow create, delete: if false;
    }

    // 大量傷患演練模組：還在建構中，目前只開放 admin 使用（前端更多頁
    // 對其他角色顯示灰階、點不進去，這裡是後端同步擋一次，避免有人繞過
    // 前端直接呼叫 API）。等模組正式開放時再放寬回所有在職帳號可用。
    match /mciEvents/{id} {
      allow read, create, update, delete: if isAdmin();
    }
    match /mciPatients/{id} {
      allow read, create, update, delete: if isAdmin();
    }

    // 洽公登記／廠商入營登記：值日官登記表，跟現有的「洽公」任務類型完全
    // 獨立（不同集合，見 index.html 的洽公登記頁）。日期沒有時間，只記錄
    // 當天有沒有排這筆登記；「已登記」是值日官謄寫進軍用電腦後勾選的狀態，
    // 跟登記內容本身（地點/車輛/事由/人員或單位）分開存取控制，值日官只能
    // 動這個狀態欄位，不能改別人送出的登記內容。
    function isCampDutyOfficer() { return isSignedIn() && myUserDoc().isCampDutyOfficer == true; }
    match /campRegistrations/{id} {
      // 讀取比照門禁登記：admin／高勤官不分單位；一般成員/主官管只看得到
      // 自己單位的登記；值日官（獨立旗標，不分原本角色）額外看得到成功嶺
      // 營區（營部＋第一連）的登記，方便值日時掌握整個營區的進出狀況。
      allow read: if isStaff() || sameUnit(resource.data.unit)
                  || (isCampDutyOfficer() && resource.data.unit in ['hq', 'co1']);
      // 建立：任何在職帳號都能登記自己單位的（createdBy 只能填自己，不能
      // 代別人的名義送出——人員/廠商欄位記錄「跟誰有關」，createdBy 記錄
      // 「誰送出這筆登記」，兩者是分開的兩件事）。
      allow create: if isActive() && request.auth.uid == request.resource.data.createdBy
                    && sameUnit(request.resource.data.unit);
      // 編輯：admin 不限；登記人本人可以改自己送出的登記（限在職帳號）；
      // 值日官（成功嶺營區範圍內）只能勾選/取消「已登記」狀態相關欄位，
      // 不能動登記內容本身。
      allow update: if isAdmin()
                    || (isActive() && request.auth.uid == resource.data.createdBy)
                    || (isCampDutyOfficer() && resource.data.unit in ['hq', 'co1']
                        && onlyChanged(['transcribed', 'transcribedBy', 'transcribedByName', 'transcribedAt']));
      // 刪除：admin 或登記人本人（限在職帳號）。
      allow delete: if isAdmin() || (isActive() && request.auth.uid == resource.data.createdBy);
    }
  }
}
