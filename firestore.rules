rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function myRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isAdmin() { return isSignedIn() && myRole() == 'admin'; }
    function isStaff() { return isSignedIn() && (myRole() == 'admin' || myRole() == 'duty_officer'); }
    function isActive() { return isSignedIn() && myRole() != 'pending'; }

    match /users/{uid} {
      allow get: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == uid
                    && request.resource.data.role == 'pending';
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /tasks/{taskId} {
      allow read: if isActive();
      allow create, update, delete: if isStaff();
    }

    match /events/{eventId} {
      allow read: if isActive();
      allow create: if isActive()
                    && (isStaff()
                        || request.auth.token.email in
                           get(/databases/$(database)/documents/tasks/$(request.resource.data.taskId)).data.assignedCrew);
      allow update, delete: if false;
    }
  }
}
