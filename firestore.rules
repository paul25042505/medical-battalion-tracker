rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function myRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isAdmin() { return isSignedIn() && myRole() == 'admin'; }
    function isStaff() { return isSignedIn() && (myRole() == 'admin' || myRole() == 'duty_officer'); }
    function isActive() { return isSignedIn() && myRole() != 'pending'; }

    match /users/{uid} {
      allow get: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == uid
                    && request.resource.data.role == 'pending';
      // 允許使用者編輯自己的個人資料（姓名/階級/單位等），但不能自己改 role 欄位；
      // role 只能由管理員（isAdmin）異動。
      allow update: if isAdmin()
                    || (isSignedIn() && request.auth.uid == uid
                        && request.resource.data.role == resource.data.role);
      allow delete: if false;
    }

    match /tasks/{taskId} {
      allow read: if isActive();
      allow create: if isActive();
      allow update, delete: if isStaff();
    }

    match /events/{eventId} {
      allow read: if isActive();
      allow create: if isActive();
      allow update, delete: if false;
    }
  }
}
